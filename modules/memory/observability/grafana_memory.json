{
  "title": "Memory Service Overview",
  "panels": [
    {"type": "graph", "title": "Searches per second", "targets": [{"expr": "rate(memory_searches_total[1m])"}]},
    {"type": "graph", "title": "Errors total", "targets": [{"expr": "rate(memory_errors_total[5m])"}]},
    {"type": "graph", "title": "Circuit breaker opens", "targets": [{"expr": "rate(memory_circuit_breaker_open_total[5m])"}]},
    {"type": "graph", "title": "Latency P95", "targets": [{"expr": "histogram_quantile(0.95, sum(rate(memory_search_latency_ms_bucket[5m])) by (le))"}]},
    {"type": "bargauge", "title": "Cache hit ratio", "targets": [{"expr": "sum(rate(memory_search_cache_hits_total[5m])) / (sum(rate(memory_search_cache_hits_total[5m])) + sum(rate(memory_search_cache_misses_total[5m])))"}]},
    {"type": "table", "title": "ANN calls by modality", "targets": [{"expr": "memory_ann_calls_total"}]}
  ]
}

