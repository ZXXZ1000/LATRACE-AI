# ===== Memory Module ENV (copy to .env and edit as needed) =====

# ---- Vector store (Qdrant) ----
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
# QDRANT_API_KEY=   # (optional, not needed for local docker default)

# ---- Graph store (Neo4j) ----
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=zx973100@123

# ---- LLM Provider (choose ONE; leave blank to use heuristics) ----
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# LLM_PROVIDER=openai_compat
# LLM_BASE_URL=https://your-compat-endpoint/v1
# LLM_API_KEY=...
# LLM_MODEL=gpt-4o-mini

# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=...
# OPENROUTER_MODEL=openai/gpt-4o-mini   # see https://openrouter.ai/models for catalog

# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=...
# DEEPSEEK_MODEL=deepseek-chat

# LLM_PROVIDER=moonshot
# MOONSHOT_API_KEY=...
# MOONSHOT_MODEL=moonshot-v1-8k

# LLM_PROVIDER=qwen
# DASHSCOPE_API_KEY=...
# QWEN_MODEL=qwen2.5

# LLM_PROVIDER=glm
# ZHIPUAI_API_KEY=...
# GLM_MODEL=glm-4

# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# ---- Embedding Provider (optional; YAML 优先) ----
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIM=1536

# OpenAI-Compatible embedding endpoint (text-only)
# OPENAI_COMPAT_API_BASE=https://api.openai.com/v1
# OPENAI_COMPAT_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Image embedding (optional; fallback if vectors missing)
# IMAGE_EMBEDDING_PROVIDER=clip   # placeholder
# IMAGE_EMBEDDING_MODEL=ViT-B/32  # placeholder
# IMAGE_EMBEDDING_DIM=512

# Audio embedding (optional; fallback if vectors missing)
# AUDIO_EMBEDDING_PROVIDER=eres2net   # placeholder
# AUDIO_EMBEDDING_MODEL=eres2netv2    # placeholder
# AUDIO_EMBEDDING_DIM=256
